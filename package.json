{
  "name": "@kontourai/ui",
  "version": "1.1.1",
  "description": "Framework-agnostic console tokens and shared UI primitives for Kontour console products.",
  "type": "module",
  "private": false,
  "license": "Apache-2.0",
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.json && tsc -p tsconfig.elements.json",
    "prepack": "npm run build",
    "check:exports": "npm run build && node scripts/check-package-exports.mjs",
    "check:tokens": "node scripts/check-tokens.mjs",
    "check:readiness": "node scripts/check-readiness.mjs",
    "check:pack": "node scripts/check-package-contents.mjs",
    "test:browser": "playwright test",
    "check": "npm run check:tokens && npm run check:exports && npm run check:readiness",
    "verify": "npm run check && npm run check:pack && npm run test:browser"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "^19.2.7",
    "typescript": "^6.0.3"
  },
  "exports": {
    "./tokens": "./tokens/index.css",
    "./tokens.css": "./tokens/tokens.css",
    "./themes.css": "./tokens/themes.css",
    "./fonts.css": "./tokens/fonts.css",
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./react/styles.css": "./react/styles.css",
    "./icons/*": "./icons/*",
    "./elements": {
      "types": "./dist/elements/elements/src/index.d.ts",
      "import": "./dist/elements/elements/src/index.js"
    }
  },
  "files": [
    "dist/",
    "docs/",
    "elements/",
    "icons/",
    "react/styles.css",
    "tokens/",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kontourai/ui.git"
  },
  "engines": {
    "node": ">=22"
  }
}
